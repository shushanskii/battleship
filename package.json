{
  "name": "battleship-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "agent": "npm start --workspace=packages/agent",
    "frontend": "npm run dev --workspace=packages/frontend",
    "format": "biome format --write packages/*/src",
    "lint": "biome check packages/*/src"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13"
  }
}
